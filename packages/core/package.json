{
  "name": "@docs/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": {
      "import": "./build/esm/index.css"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@docs/typescript-config": "workspace:*",
    "@vitest/ui": "^3.0.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "prosemirror-model": "^1.25.9"
  }
}
